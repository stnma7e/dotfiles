{
  "layer": "top",
  "position": "top",
  "margin-top": -7, // this is a little gross, but I want it to touch the top of the screen
  "margin-left": -10,
  "margin-bottom": 0,
  "spacing": 0,
  "modules-left": [
    "sway/workspaces",
    "cpu"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "bluetooth",
    "network",
    "pulseaudio#builtin",
    "pulseaudio#polk",
    "backlight",
    "battery",
    "clock"
  ],
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "",
      "default": ""
    }
  },
  "bluetooth": {
    "format": "󰂲",
    "format-on": "{icon}",
    "format-off": "{icon}",
    "format-connected": "{icon}",
    "format-icons": {
      "on": "󰂯",
      "off": "󰂲",
      "connected": "󰂱"
    },
    "on-click": "blueman-manager",
    "tooltip-format-connected": "{device_enumerate}"
  },
  "clock": {
    "format": "{:%H:%M:%S  -  %A, %d}",
    "interval": 1
  },
  "network": {
    "format-wifi": "󰤢",
    "format-ethernet": "󰈀 ",
    "format-disconnected": "󰤠 ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"
  },
  "cpu": {
    "interval": 1,
    "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": [
      "▁",
      "▂",
      "▃",
      "▄",
      "▅",
      "▆",
      "▇",
      "█"
    ],
    "on-click": "ghostty -e htop"
  },
  "memory": {
    "interval": 30,
    "format": "  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": [
      "",
      "󰃜",
      "󰃛",
      "󰃞",
      "󰃝",
      "󰃟",
      "󰃠"
    ],
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "",
    "format-icons": {
      "default": [
        "",
        "",
        " "
      ]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "interval": 2,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },
  "pulseaudio#builtin": {
      "format": "{volume}% {icon}   ",
      "ignored-sinks": ["bluez_output.14_4E_FD_31_36_52.1"], // this doesn't work
      "format-muted": "",
      "format-icons": { "default": ["  ", "  ", "  "] },

      "on-click": "pactl set-sink-mute alsa_output.pci-0000_00_1f.3.analog-stereo toggle",
      "on-click-right": "pavucontrol",
      "on-scroll-up": "pactl set-sink-volume alsa_output.pci-0000_00_1f.3.analog-stereo +5%",
      "on-scroll-down": "pactl set-sink-volume alsa_output.pci-0000_00_1f.3.analog-stereo -5%"
  },
  "pulseaudio#polk": {
      "format": "{volume}% {icon}   ",
      "format-muted": "",
      "format-icons": { "default": ["  ", "  ", "  "] },
      "on-click": "pactl set-sink-mute bluez_output.14_4E_FD_31_36_52.1 toggle",
      "on-scroll-up": "pactl set-sink-volume bluez_output.14_4E_FD_31_36_52.1 +5%",
      "on-scroll-down": "pactl set-sink-volume bluez_output.14_4E_FD_31_36_52.1 -5%"
  }
}
